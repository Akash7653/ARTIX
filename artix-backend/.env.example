PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/?appName=your_app_name
FRONTEND_URL=https://artix-iota.vercel.app
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_EMAIL=admin@example.com

# Email Notifications (Gmail - requires App Password)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# WhatsApp Notifications (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155552671
TWILIO_SMS_NUMBER=+14155552671
# Admin WhatsApp Phone Number
# This is the admin's phone number that participants can contact
# Format: +country_code_phone_number (e.g., +918919068236 for India)
ADMIN_PHONE_NUMBER=+918919068236